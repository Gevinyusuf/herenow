## 4\. Prisma Schema (针对 Next.js 的最佳实践)

如果你使用 Prisma ORM，请直接复制以下内容到 `schema.prisma`：

```prisma
// schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserIntent {
  CONSUMER
  ORGANIZER
  HYBRID
}

enum SubStatus {
  active
  canceled
  past_due
  trialing
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELED
  ENDED
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum RegStatus {
  PENDING
  CONFIRMED
  CANCELED
  CHECKED_IN
}

model User {
  id            BigInt    @id @default(autoincrement())
  email         String    @unique
  full_name     String?
  avatar_url    String?
  primary_intent UserIntent @default(HYBRID)
  created_at    DateTime  @default(now())

  subscription  Subscription?
  owned_communities Community[]  @relation("Owner")
  memberships   CommunityMember[]
  registrations Registration[]
  created_events Event[]
}

model Plan {
  id            Int      @id
  name          String
  price_monthly Decimal  @db.Decimal(10, 2)
  limits        Json     // 核心权益配置
  is_active     Boolean  @default(true)
  
  subscriptions Subscription[]
}

model Subscription {
  id                  BigInt    @id @default(autoincrement())
  user_id             BigInt    @unique
  plan_id             Int
  status              SubStatus @default(active)
  current_period_end  DateTime?
  
  user                User      @relation(fields: [user_id], references: [id])
  plan                Plan      @relation(fields: [plan_id], references: [id])
}

model Community {
  id          BigInt   @id @default(autoincrement())
  owner_id    BigInt
  name        String
  slug        String   @unique
  settings    Json?    @default("{}")
  created_at  DateTime @default(now())

  owner       User     @relation("Owner", fields: [owner_id], references: [id])
  events      Event[]
  members     CommunityMember[]
}

model Event {
  id              BigInt      @id @default(autoincrement())
  community_id    BigInt
  creator_id      BigInt
  title           String
  slug            String      @unique
  start_time      DateTime
  end_time        DateTime
  status          EventStatus @default(DRAFT)
  location_config Json?
  description     String?     @db.Text
  
  community       Community     @relation(fields: [community_id], references: [id])
  creator         User          @relation(fields: [creator_id], references: [id])
  registrations   Registration[]
}

model CommunityMember {
  id            BigInt   @id @default(autoincrement())
  community_id  BigInt
  user_id       BigInt
  role          MemberRole @default(MEMBER)
  source        String?
  joined_at     DateTime   @default(now())

  community     Community @relation(fields: [community_id], references: [id])
  user          User      @relation(fields: [user_id], references: [id])

  @@unique([community_id, user_id])
}

model Registration {
  id            BigInt    @id @default(autoincrement())
  event_id      BigInt
  user_id       BigInt
  status        RegStatus @default(CONFIRMED)
  created_at    DateTime  @default(now())
  
  event         Event     @relation(fields: [event_id], references: [id])
  user          User      @relation(fields: [user_id], references: [id])
}
```

## 5\. 关键业务逻辑实施建议

1.  **随机 Slug 生成**：不要在数据库层做，在应用层 (Node.js) 使用 `nanoid` 库生成，例如 `nanoid(10)`。如果插入时报错（极小概率冲突），Catch error 并重试一次即可。
2.  **配额校验 (Guard Logic)**：
      * 在 `createEvent` API 中，先 `await prisma.user.findUnique({ include: { subscription: { include: { plan: true } } } })`。
      * 读取 `plan.limits.max_events`。
      * 对比 `await prisma.event.count(...)`。
3.  **报名即入群**：
      * 使用 `prisma.$transaction` 包裹报名逻辑。
      * 第一步：创建 `Registration`。
      * 第二步：`upsert` 写入 `CommunityMember`（如果存在则忽略，不存在则创建）。
