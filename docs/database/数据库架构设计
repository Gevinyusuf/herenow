### 3.2 内容与社群模块

#### `communities` (社群/组织者主页)

活动必须挂载在社群下。

```sql
CREATE TABLE communities (
    id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    owner_id BIGINT NOT NULL REFERENCES users(id), -- 创建者
    
    name VARCHAR(100) NOT NULL,
    description TEXT,
    
    -- 随机 Slug (e.g. 'club-x9s2')，作为 URL 标识
    slug VARCHAR(30) UNIQUE NOT NULL,
    
    -- 社群配置：是否审核加入、Logo设置、联系方式
    settings JSONB DEFAULT '{}',
    
    created_at TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX idx_communities_owner ON communities(owner_id);
```

#### `events` (活动表)

核心业务实体。

```sql
CREATE TABLE events (
    id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    community_id BIGINT NOT NULL REFERENCES communities(id), -- 强关联
    creator_id BIGINT NOT NULL REFERENCES users(id),
    
    title VARCHAR(255) NOT NULL,
    -- 随机 Slug (e.g. 'evt-8821')
    slug VARCHAR(50) UNIQUE NOT NULL,
    
    start_time TIMESTAMPTZ NOT NULL,
    end_time TIMESTAMPTZ NOT NULL,
    
    -- 核心状态机：'DRAFT', 'PUBLISHED', 'CANCELED', 'ENDED'
    status VARCHAR(20) DEFAULT 'DRAFT',
    
    -- 活动详情：地点(线上/线下)、富文本描述、封面图
    -- 使用 JSONB 存储结构化地点信息 { "type": "offline", "address": "..." }
    location_config JSONB, 
    description TEXT,
    
    -- 票务简易配置 (MVP版本)
    capacity INT DEFAULT 100,
    is_public BOOLEAN DEFAULT TRUE,
    
    created_at TIMESTAMPTZ DEFAULT NOW()
);

-- 索引：查询某个社群下的活动
CREATE INDEX idx_events_community ON events(community_id);
-- 索引：查询公开且已发布的活动 (发现页 Feeds)
CREATE INDEX idx_events_feed ON events(start_time) WHERE status = 'PUBLISHED' AND is_public = TRUE;
```

